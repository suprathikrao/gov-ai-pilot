# --- Database ---
# Replace this with your Supabase connection string, for example:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://govai:govai_password@db:5432/govai_copilot

# --- Auth / JWT ---
JWT_SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File storage ---
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_MB=10

# --- OCR ---
TESSERACT_CMD=/usr/bin/tesseract

# --- Vector DB / LLM (Phase 5) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=govai_documents
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://ollama:11434

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
